php_flag engine off
Options -ExecCGI -Indexes

<FilesMatch "\.(php|php3|php4|php5|phtml|phar|js|json|go|py|rb|pl|cgi|sh|bat|exe|msi|dll|jar|class|cs|vb|config|csproj|sln)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
